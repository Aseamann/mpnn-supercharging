# ── Project-specific ───────────────────────────────────────────────────────────
# PyRosetta surface/charge parse cache
parsed/

# Threaded PDB output directories (generated at runtime)
threaded*/

# ProteinMPNN output FASTA files (keep example inputs, ignore generated outputs)
*.fa
*.fasta
# Re-include example reference FASTA files if needed (none currently tracked)

# PyMOL scripts generated in verbose mode
*.pml

# Pickle files (runtime cache)
*.pkl

# SLURM job logs
slurm_*.out
slurm_*.err

# Example output files generated by test runs (PDB inputs are tracked)
examples/*/parsed/
examples/*/*.fa
examples/*/*.fasta

